PORT=8000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# Use DATABASE_URL, or the PG* variables below.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/medvision
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=medvision
# PGUSER=postgres
# PGPASSWORD=postgres
# PGSSL=false

MAX_UPLOAD_MB=100
UPLOAD_DIR=./uploads
PG_POOL_MAX=10
RATE_LIMIT_PER_MINUTE=120
